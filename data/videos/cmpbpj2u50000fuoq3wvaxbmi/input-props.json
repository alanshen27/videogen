        "layoutPreset": "code_and_callouts",
        "elements": [
          {
            "type": "code",
            "content": "```typescript\n// Simple feed query first\nconst posts = await prisma.$queryRaw`\n  SELECT posts.*\n  FROM posts\n  JOIN follows ON follows.followingId = posts.authorId\n  WHERE follows.followerId = ${currentUserId}\n  ORDER BY posts.createdAt DESC\n  LIMIT 20\n`\n\n// Later: fanout on write\nfor (const followerId of followers) {\n  await redis.zadd(`feed:${followerId}`, post.createdAt, post.id)\n}\n```",
            "iconName": null,
            "width": null,
            "height": null,
