        "elements": [
          {
            "type": "text",
            "content": "Pick, then relax\n\nThe loop is small. Pick the closest unvisited node, then check whether its roads give cheaper paths to its neighbors.\n\n- Choose the smallest unvisited distance\n- Mark that node as done\n- Try cheaper paths to neighbors",
            "iconName": "Sparkles",
            "width": null,
            "height": null,
            "x": 118,
            "y": 124,
