        "layoutPreset": "title_hero_and_canvas",
        "elements": [
          {
            "type": "text",
            "content": "The greedy rule\n\nDijkstra does not guess the whole path at once. It makes one safe choice, then repeats.\n\n- Pick the closest unfinished node\n- Lock in that distance\n- Check its neighbors\n- Keep the best updates",
            "iconName": "Sparkles",
            "width": null,
