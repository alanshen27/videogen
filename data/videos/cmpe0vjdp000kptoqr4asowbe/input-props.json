        "layoutPreset": "code_and_callouts",
        "elements": [
          {
            "type": "code",
            "content": "```python\nleft, right = 0, len(a) - 1\n\nwhile left < right:\n    sum = a[left] + a[right]\n\n    if sum == target:\n        return (left, right)\n    elif sum < target:\n        left += 1\n    else:\n        right -= 1\n\nreturn None\n```",
            "iconName": null,
            "width": null,
